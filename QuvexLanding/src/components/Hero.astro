---
interface Props {
  badge?: string;
  title?: string;
  highlight?: string;
  subtitle?: string;
}
const {
  badge = 'Uretim ERP Platformu',
  title = 'Fabrikanizi',
  highlight = 'Dijitallestirin',
  subtitle = 'Kucuk ve orta olcekli fabrikalar icin AS9100-hazir, kullanici dostu uretim yonetim platformu. Uretim, stok, kalite ve finans tek platformda.',
} = Astro.props;
---
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">{badge}</div>
    <h1>{title} <span>{highlight}</span></h1>
    <p>{subtitle}</p>
    <div class="hero-btns">
      <a href="https://app.quvex.io/register" class="btn btn-primary">14 Gun Ucretsiz Dene →</a>
      <a href="/demo" class="btn btn-outline-light">Demo Iste</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><div class="hero-stat-num">900+</div><div class="hero-stat-label">API Endpoint</div></div>
      <div class="hero-stat"><div class="hero-stat-num">60+</div><div class="hero-stat-label">Ekran</div></div>
      <div class="hero-stat"><div class="hero-stat-num">18</div><div class="hero-stat-label">Sektor</div></div>
      <div class="hero-stat"><div class="hero-stat-num">5dk</div><div class="hero-stat-label">Kurulum</div></div>
    </div>
  </div>
</section>

<style>
  .hero { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%); color: #fff; padding: 100px 24px 110px; text-align: center; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: -120px; right: -100px; width: 420px; height: 420px; border-radius: 50%; background: rgba(99,102,241,0.10); }
  .hero::after { content: ''; position: absolute; bottom: -80px; left: -60px; width: 320px; height: 320px; border-radius: 50%; background: rgba(139,92,246,0.08); }
  .hero-content { position: relative; z-index: 1; max-width: 820px; margin: 0 auto; }
  .hero-badge { display: inline-block; padding: 6px 16px; border-radius: 20px; background: rgba(99,102,241,0.15); color: #a5b4fc; font-size: 13px; font-weight: 600; margin-bottom: 24px; border: 1px solid rgba(99,102,241,0.25); }
  .hero h1 { font-size: clamp(34px, 5.5vw, 60px); font-weight: 900; line-height: 1.08; margin-bottom: 22px; letter-spacing: -1.2px; }
  .hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero p { font-size: 19px; color: rgba(255,255,255,0.7); max-width: 640px; margin: 0 auto 38px; }
  .hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .hero-stats { display: flex; justify-content: center; gap: 56px; margin-top: 64px; flex-wrap: wrap; }
  .hero-stat-num { font-size: 30px; font-weight: 800; color: #fff; }
  .hero-stat-label { font-size: 13px; color: rgba(255,255,255,0.55); margin-top: 4px; }

  @media (max-width: 640px) {
    .hero { padding: 70px 20px 80px; }
    .hero-stats { gap: 28px; margin-top: 44px; }
    .hero-stat-num { font-size: 22px; }
  }
</style>
