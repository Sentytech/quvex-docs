---
interface Props {
  sector: string;
  hero: string;
  heroSub: string;
  pains: string[];
  solutions: string[];
  features: { icon: string; title: string; desc: string }[];
  caseStudy?: { company: string; quote: string; author: string; result: string };
}
const { sector, hero, heroSub, pains, solutions, features, caseStudy } = Astro.props;
---
<section class="page-hero">
  <div class="sector-badge">{sector}</div>
  <h1>{hero}</h1>
  <p>{heroSub}</p>
  <div style="margin-top: 30px;">
    <a href="/demo" class="btn btn-primary">Bu sektor icin demo iste →</a>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="problem-solution">
      <div class="ps-col pain">
        <div class="ps-eyebrow">Sorun</div>
        <h2>Sektorunuzun Tipik Problemleri</h2>
        <ul>
          {pains.map(p => <li>{p}</li>)}
        </ul>
      </div>
      <div class="ps-col sol">
        <div class="ps-eyebrow">Cozum</div>
        <h2>Quvex Nasil Cozer?</h2>
        <ul>
          {solutions.map(s => <li>{s}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="section" style="background: #f9fafb;">
  <div class="container">
    <div class="section-title">
      <div class="eyebrow">Sektore Ozel</div>
      <h2>{sector} Icin Ozel Ozellikler</h2>
    </div>
    <div class="sector-features">
      {features.map(f => (
        <div class="sf-card">
          <div class="sf-icon">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{caseStudy && (
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <div class="case-study">
        <div class="eyebrow">Musteri Hikayesi</div>
        <div class="case-company">{caseStudy.company}</div>
        <p class="case-quote">"{caseStudy.quote}"</p>
        <div class="case-foot">
          <div class="case-author">— {caseStudy.author}</div>
          <div class="case-result">{caseStudy.result}</div>
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .sector-badge { display: inline-block; padding: 5px 14px; border-radius: 14px; background: rgba(99,102,241,0.2); color: #a5b4fc; font-size: 13px; font-weight: 700; margin-bottom: 18px; border: 1px solid rgba(99,102,241,0.3); }

  .problem-solution { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .ps-col { padding: 34px; border-radius: 18px; border: 1px solid #e5e7eb; }
  .ps-col.pain { background: #fef2f2; border-color: #fecaca; }
  .ps-col.sol { background: #f0fdf4; border-color: #bbf7d0; }
  .ps-eyebrow { display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 12px; }
  .pain .ps-eyebrow { background: #fee2e2; color: #b91c1c; }
  .sol .ps-eyebrow { background: #dcfce7; color: #15803d; }
  .ps-col h2 { font-size: 22px; font-weight: 800; margin-bottom: 18px; }
  .ps-col ul { list-style: none; padding: 0; }
  .ps-col li { padding: 10px 0 10px 28px; color: #374151; font-size: 15px; position: relative; border-bottom: 1px solid rgba(0,0,0,0.04); }
  .pain li::before { content: '✕'; position: absolute; left: 0; color: #dc2626; font-weight: 900; }
  .sol li::before { content: '✓'; position: absolute; left: 0; color: #16a34a; font-weight: 900; }

  .sector-features { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 22px; }
  .sf-card { background: #fff; padding: 28px; border-radius: 14px; border: 1px solid #e5e7eb; transition: all 0.2s; }
  .sf-card:hover { border-color: #c7d2fe; box-shadow: 0 10px 28px rgba(99,102,241,0.08); }
  .sf-icon { font-size: 34px; margin-bottom: 10px; }
  .sf-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .sf-card p { font-size: 14px; color: #6b7280; line-height: 1.6; }

  .case-study { background: linear-gradient(135deg, #eef2ff, #f5f3ff); border-radius: 20px; padding: 50px 44px; border: 1px solid #e0e7ff; text-align: center; }
  .eyebrow { display: inline-block; padding: 4px 14px; border-radius: 14px; background: #fff; color: #6366f1; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; }
  .case-company { font-size: 32px; font-weight: 900; margin-bottom: 18px; color: #1a1d3b; letter-spacing: -0.5px; }
  .case-quote { font-size: 18px; line-height: 1.7; color: #374151; font-style: italic; margin-bottom: 24px; }
  .case-foot { display: flex; justify-content: space-between; align-items: center; padding-top: 22px; border-top: 1px solid rgba(0,0,0,0.08); }
  .case-author { color: #6b7280; font-weight: 600; }
  .case-result { background: #22c55e; color: #fff; padding: 8px 16px; border-radius: 10px; font-size: 13px; font-weight: 700; }

  @media (max-width: 820px) {
    .problem-solution { grid-template-columns: 1fr; gap: 22px; }
    .case-foot { flex-direction: column; gap: 12px; }
  }
</style>
