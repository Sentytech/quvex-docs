---
interface Props {
  title?: string;
  subtitle?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}
const {
  title = 'Fabrikanizi dijitallestirmeye bugun baslayin',
  subtitle = '14 gun ucretsiz deneyin. Kredi karti gerekmez. 5 dakikada kurulum.',
  primaryHref = 'https://app.quvex.io/register',
  primaryLabel = 'Ucretsiz Dene',
  secondaryHref = '/demo',
  secondaryLabel = 'Demo Iste',
} = Astro.props;
---
<section class="cta-section">
  <div class="cta-inner">
    <h2>{title}</h2>
    <p>{subtitle}</p>
    <div class="cta-btns">
      <a href={primaryHref} class="btn btn-primary">{primaryLabel} →</a>
      <a href={secondaryHref} class="btn btn-outline-light">{secondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-section { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%); color: #fff; padding: 80px 24px; text-align: center; position: relative; overflow: hidden; }
  .cta-section::before { content: ''; position: absolute; top: -100px; right: -100px; width: 320px; height: 320px; border-radius: 50%; background: rgba(99,102,241,0.12); }
  .cta-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }
  .cta-inner h2 { font-size: clamp(28px, 4.5vw, 40px); font-weight: 900; margin-bottom: 14px; letter-spacing: -0.8px; }
  .cta-inner p { font-size: 18px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
</style>
