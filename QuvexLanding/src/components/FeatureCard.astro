---
interface Props {
  icon: string;
  title: string;
  desc: string;
}
const { icon, title, desc } = Astro.props;
---
<div class="feature-card">
  <div class="feature-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{desc}</p>
</div>

<style>
  .feature-card { padding: 28px; border-radius: 16px; border: 1px solid #e5e7eb; transition: all 0.2s; background: #fff; }
  .feature-card:hover { border-color: #c7d2fe; box-shadow: 0 10px 30px rgba(99,102,241,0.10); transform: translateY(-3px); }
  .feature-icon { font-size: 34px; margin-bottom: 12px; }
  h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: #1a1d3b; }
  p { color: #6b7280; font-size: 14px; line-height: 1.6; }
</style>
