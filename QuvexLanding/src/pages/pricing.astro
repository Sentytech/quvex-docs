---
import Layout from '../layouts/Layout.astro';
import PricingCard from '../components/PricingCard.astro';
import RoiCalculator from '../components/RoiCalculator.astro';
import CTASection from '../components/CTASection.astro';

const plans = [
  {
    name: 'Baslangic',
    priceUsd: 99,
    priceTl: '3.000',
    users: '5 kullanici dahil',
    features: ['Temel Uretim (is emri, BOM)', 'Stok Yonetimi (1 depo)', 'Satis & Fatura', 'Mobil Uygulama', '18 Sektor Sablonu', 'Temel Raporlar', 'Turkce E-Posta Destek'],
    popular: false,
  },
  {
    name: 'Pro',
    priceUsd: 199,
    priceTl: '6.000',
    users: '25 kullanici dahil',
    features: ['Baslangic +', 'Kalite Modulu (NCR, CAPA, FAI)', 'AS9100 / IATF / HACCP / CE', 'MRP & Kapasite Planlama', 'Bakim & OEE', '5 Makine Terminal', '5 Depo', 'Telefon Destek'],
    popular: true,
  },
  {
    name: 'Enterprise',
    priceUsd: 399,
    priceTl: '12.000',
    users: 'Sinirsiz kullanici',
    features: ['Pro +', 'AI Insights (gecikme riski, anomali)', 'API Erisimi + Webhook', 'Ozel Entegrasyon (SAP, Logo)', 'Oncelikli Destek (4 saat SLA)', 'Sinirsiz Makine & Depo', 'Dedicated CSM', 'On-Premise Secenegi'],
    popular: false,
  },
];

const comparisonRows = [
  { f: 'Kullanici sayisi', s: '5', p: '25', e: 'Sinirsiz' },
  { f: 'Depo sayisi', s: '1', p: '5', e: 'Sinirsiz' },
  { f: 'Is Emri & BOM', s: true, p: true, e: true },
  { f: 'Stok & Lot takip', s: true, p: true, e: true },
  { f: 'Barkod & Etiket', s: true, p: true, e: true },
  { f: 'Satis & Fatura', s: true, p: true, e: true },
  { f: '18 Sektor Sablonu', s: true, p: true, e: true },
  { f: '5dk Onboarding', s: true, p: true, e: true },
  { f: 'Persona Dashboard (8 rol)', s: true, p: true, e: true },
  { f: 'Mobil Uygulama', s: true, p: true, e: true },
  { f: 'NCR / CAPA', s: 'Temel', p: true, e: true },
  { f: 'FAI / PPAP', s: false, p: true, e: true },
  { f: 'AS9100 Uyumluluk', s: false, p: true, e: true },
  { f: 'IATF 16949 (Otomotiv)', s: false, p: true, e: true },
  { f: 'HACCP (Gida)', s: false, p: true, e: true },
  { f: 'CE Technical File', s: false, p: true, e: true },
  { f: 'WPS / WPQR (Kaynak)', s: false, p: true, e: true },
  { f: 'MRP & Kapasite', s: false, p: true, e: true },
  { f: 'Bakim & OEE', s: false, p: true, e: true },
  { f: 'ShopFloor Terminal', s: '1 makine', p: '5 makine', e: 'Sinirsiz' },
  { f: 'Traceability (lot/seri)', s: 'Temel', p: true, e: true },
  { f: 'Real-time Uretim Panosu', s: false, p: true, e: true },
  { f: 'WhatsApp Bildirim (8 sablon)', s: false, p: true, e: true },
  { f: 'SPC / FMEA', s: false, p: true, e: true },
  { f: 'MRB / 8D Report', s: false, p: true, e: true },
  { f: 'ProductVariant (Tekstil)', s: false, p: true, e: true },
  { f: 'HACCP Recall Simulasyon', s: false, p: true, e: true },
  { f: 'MoldInventory (Plastik)', s: false, p: true, e: true },
  { f: 'AI Gecikme Riski', s: false, p: false, e: true },
  { f: 'AI Tedarikci Puanlama', s: false, p: false, e: true },
  { f: 'AI Anomali Tespiti', s: false, p: false, e: true },
  { f: 'Tahminsel Bakim', s: false, p: false, e: true },
  { f: 'API + Webhook', s: false, p: false, e: true },
  { f: 'Ozel Entegrasyon (SAP vb.)', s: false, p: false, e: true },
  { f: 'On-Premise Kurulum', s: false, p: false, e: true },
  { f: 'SSO / SAML', s: false, p: false, e: true },
  { f: 'Dedicated CSM', s: false, p: false, e: true },
  { f: 'Destek SLA', s: '48 saat', p: '24 saat', e: '4 saat' },
  { f: 'Yedekleme', s: 'Gunluk', p: 'Saatlik', e: 'Real-time' },
  { f: 'Uptime garantisi', s: '99.5%', p: '99.9%', e: '99.99%' },
];

const faqs = [
  { q: 'Kredi karti olmadan deneyebilir miyim?', a: '14 gun boyunca tam ozellikli deneme sunuyoruz. Kredi karti istemiyoruz. Deneme bitince otomatik ucretlendirme YOK.' },
  { q: 'Fiyatlar KDV dahil mi?', a: 'Hayir, fiyatlar KDV haric. Turkiye faturaniz %20 KDV ile duzenlenir.' },
  { q: 'Yillik odemede indirim var mi?', a: 'Evet, yillik odeme %20 indirimlidir. Baslangic $950, Pro $1.910, Enterprise $3.830 / yil.' },
  { q: 'Istedigim zaman plan degistirebilir miyim?', a: 'Evet, hem yukarida hem asagida plan degisikligi anlik. Farkli tutar o ay pro-rata hesaplanir.' },
  { q: 'Iptal ettigimde verilerim ne olur?', a: 'Tum verilerinizi CSV/Excel olarak export edebilirsiniz. 30 gun arsivde tutuyoruz.' },
  { q: 'Kurulum ucreti var mi?', a: 'Hayir. Baslangic ve Pro planlarinda kurulum ucretsiz. Enterprise ozel entegrasyon ucreti degisir.' },
  { q: 'Egitim veriyor musunuz?', a: 'Evet. 5dk Onboarding video + canli webinar + dokumantasyon ucretsiz. Ozel egitim Enterprise icin dahildir.' },
  { q: 'Demo gorebilir miyim?', a: 'Elbette. Demo randevusu icin /demo sayfamizdan form doldurun, 24 saat icinde doneriz.' },
  { q: 'Turkiye disinda kullanabilir miyim?', a: 'Evet. Cloud hosting (AWS Frankfurt), coklu dil (TR/EN), coklu para birimi destekler.' },
  { q: 'Veri guvenligi nasil?', a: 'ISO 27001 hazirliginda, AES-256-GCM sifreleme, schema-per-tenant izolasyon, gunluk yedek. Detay: Sartlar & Gizlilik sayfalari.' },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Quvex ERP',
  description: 'Kucuk ve orta olcekli fabrikalar icin AS9100-hazir uretim yonetim platformu',
  offers: plans.map(p => ({
    '@type': 'Offer',
    name: p.name,
    price: p.priceUsd,
    priceCurrency: 'USD',
  })),
});
---
<Layout
  title="Fiyatlandirma - Quvex ERP | 3 Plan, $99'dan Baslayan"
  description="Quvex ERP fiyatlari: Baslangic $99, Pro $199, Enterprise $399. Seffaf, aylik, istenildigi zaman iptal. 14 gun ucretsiz deneme."
  schema={schema}
>
  <section class="page-hero">
    <h1>Basit, Seffaf Fiyatlandirma</h1>
    <p>Gizli ucret yok. Kullanici basi fiyatlandirma yok. Firma basi sabit aylik ucret.</p>

    <div class="toggle-wrap">
      <button id="tg-monthly" class="toggle active">Aylik</button>
      <button id="tg-yearly" class="toggle">Yillik <span class="badge-save">%20 indirim</span></button>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pricing-grid">
        {plans.map((p, i) => (
          <div class="pricing-slot" data-idx={i}>
            <PricingCard
              name={p.name}
              priceUsd={p.priceUsd}
              priceTl={p.priceTl}
              users={p.users}
              features={p.features}
              popular={p.popular}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="section" style="background: #f9fafb;">
    <div class="container">
      <div class="section-title">
        <div class="eyebrow">Detayli Karsilastirma</div>
        <h2>Hangi Plan Bana Uygun?</h2>
        <p>40+ ozellik plan bazinda karsilastirma</p>
      </div>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Ozellik</th>
              <th>Baslangic</th>
              <th class="pop">Pro</th>
              <th>Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map(row => (
              <tr>
                <td>{row.f}</td>
                <td>{row.s === true ? '✓' : row.s === false ? '—' : row.s}</td>
                <td class="pop">{row.p === true ? '✓' : row.p === false ? '—' : row.p}</td>
                <td>{row.e === true ? '✓' : row.e === false ? '—' : row.e}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <RoiCalculator compact={true} />

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <div class="section-title">
        <div class="eyebrow">SSS</div>
        <h2>Sikca Sorulan Sorular</h2>
      </div>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  .toggle-wrap { display: inline-flex; margin-top: 32px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 5px; }
  .toggle { padding: 10px 22px; border-radius: 9px; background: transparent; color: rgba(255,255,255,0.7); border: none; cursor: pointer; font-weight: 600; font-size: 14px; font-family: inherit; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
  .toggle.active { background: #fff; color: #1a1d3b; }
  .badge-save { background: #22c55e; color: #fff; font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 700; }

  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; max-width: 1100px; margin: 0 auto; }

  .compare-table-wrap { overflow-x: auto; background: #fff; border-radius: 16px; border: 1px solid #e5e7eb; }
  .compare-table { width: 100%; border-collapse: collapse; min-width: 680px; }
  .compare-table th, .compare-table td { padding: 14px 20px; text-align: left; font-size: 14px; border-bottom: 1px solid #f3f4f6; }
  .compare-table th { background: #f9fafb; font-weight: 700; color: #1a1d3b; position: sticky; top: 0; }
  .compare-table th.pop, .compare-table td.pop { background: #eef2ff; color: #4338ca; font-weight: 600; }
  .compare-table th.pop { background: #6366f1; color: #fff; }
  .compare-table tbody tr:hover { background: #fafafa; }
  .compare-table td:first-child { font-weight: 500; color: #374151; }
  .compare-table td:not(:first-child) { text-align: center; color: #6b7280; }

  .faq-list { display: flex; flex-direction: column; gap: 10px; }
  .faq-item { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 18px 22px; transition: all 0.2s; }
  .faq-item[open] { border-color: #c7d2fe; box-shadow: 0 6px 20px rgba(99,102,241,0.06); }
  .faq-item summary { cursor: pointer; font-weight: 700; font-size: 15px; color: #1a1d3b; list-style: none; display: flex; justify-content: space-between; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 22px; color: #6366f1; font-weight: 300; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { color: #6b7280; margin-top: 12px; font-size: 14px; line-height: 1.7; }

  @media (max-width: 820px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const btnM = document.getElementById('tg-monthly');
  const btnY = document.getElementById('tg-yearly');
  const slots = document.querySelectorAll<HTMLElement>('.pricing-slot .price-amount');
  const prices = [99, 199, 399];

  function renderPrices(yearly: boolean) {
    slots.forEach((el, i) => {
      const base = prices[i];
      if (!base) return;
      const shown = yearly ? Math.round(base * 0.8) : base;
      const period = el.querySelector('.price-period');
      el.childNodes.forEach(n => {
        if (n.nodeType === 3 && n.textContent && /\d/.test(n.textContent)) {
          n.textContent = String(shown);
        }
      });
      if (period) period.textContent = yearly ? '/ay (yillik)' : '/ay';
    });
  }

  btnM?.addEventListener('click', () => {
    btnM.classList.add('active');
    btnY?.classList.remove('active');
    renderPrices(false);
  });
  btnY?.addEventListener('click', () => {
    btnY.classList.add('active');
    btnM?.classList.remove('active');
    renderPrices(true);
  });
</script>
